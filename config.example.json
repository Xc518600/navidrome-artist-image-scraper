{
  "music_root": "/music",
  "cache_dir": "/app/cache",
  "request_timeout": 20,
  "user_agent": "navidrome-artist-image-scraper/0.1",
  "providers": ["override", "netease", "theaudiodb", "deezer"],
  "audio_extensions": [
    ".mp3", ".flac", ".m4a", ".aac", ".ogg", ".opus", ".wav", ".aiff", ".ape", ".wma", ".dsf"
  ],
  "skip_dirs": [
    "attachments",
    ".git",
    "cache",
    "__pycache__"
  ],
  "artist_aliases": {
    "周杰倫": "周杰伦",
    "张韶涵": "Angela Chang",
    "邓紫棋": "G.E.M. 邓紫棋"
  },
  "navidrome_export_dir": "/config/navidrome-artist-images",
  "navidrome_artist_aliases": {
    "周杰伦": ["周杰倫", "Jay Chou"],
    "G.E.M. 邓紫棋": ["邓紫棋", "G.E.M.邓紫棋"],
    "伍佰 & China Blue": ["Wu Bai (伍佰) & China Blue"]
  },
  "overrides": {}
}
